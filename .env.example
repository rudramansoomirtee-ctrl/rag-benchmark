# AWS Bedrock credentials (required for Systems A–D)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2

# LiteLLM model string. Use the `eu.` prefix for cross-region inference.
LITELLM_MODEL=bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0

# Postgres (docker-compose defaults to `ragbench` if unset)
POSTGRES_PASSWORD=ragbench

# System E (OpenRag) — URL of a running ultimate_rag server with the MultiHop
# corpus ingested. Must be reachable from the api container: on Docker Desktop
# use http://host.docker.internal:8000; on Linux add an `openrag` compose
# service and use http://openrag:8000. Only needed when running `--systems E`.
OPENRAG_URL=http://host.docker.internal:8000
