# AWS Bedrock credentials (required for Systems A–D)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2

# LiteLLM model string. Use the `eu.` prefix for cross-region inference.
LITELLM_MODEL=bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0

# Optional: model for the CRAG LLM-as-judge, independent of generation so you can
# run cheap generation + strong judging. Defaults to LITELLM_MODEL when unset.
# Any LiteLLM provider works (bedrock/…, deepseek/deepseek-chat, gemini/…, openai/…).
# JUDGE_MODEL=bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0

# API keys for cheap generation providers — only if you point LITELLM_MODEL/JUDGE_MODEL at them.
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# Logging: INFO = milestones + failures; DEBUG = per-run + per-agent-step play-by-play.
# LOG_LEVEL=INFO

# Postgres (docker-compose defaults to `ragbench` if unset)
POSTGRES_PASSWORD=ragbench

# System E (vendored OpenRag) — only needed when running `--systems E`.
# OpenRag builds its RAPTOR index with OpenAI (embeddings + gpt-4o-mini summaries)
# and reranks with Cohere. Without COHERE_API_KEY it falls back to a local
# cross-encoder (lower recall).
OPENAI_API_KEY=
COHERE_API_KEY=
