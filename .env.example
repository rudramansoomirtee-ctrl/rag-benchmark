# AWS Bedrock credentials (required for Systems A–D)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2

# LiteLLM model string. Use the `eu.` prefix for cross-region inference.
LITELLM_MODEL=bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0

# Postgres (docker-compose defaults to `ragbench` if unset)
POSTGRES_PASSWORD=ragbench
